{
  "info": {
    "name": "Task Tracker Auth API",
    "description": "Registration, login, protected task routes, ownership authorization, admin RBAC, and per-endpoint rate limiting.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "userAToken", "value": "" },
    { "key": "userBToken", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "taskId", "value": "" }
  ],
  "item": [
    {
      "name": "Registration",
      "item": [
        {
          "name": "Register User A - success (201)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alice\",\n  \"email\": \"alice@example.com\",\n  \"password\": \"password123\"\n}"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.test('token present', () => pm.expect(body.data.token).to.be.a('string'));",
                  "pm.test('password not returned', () => pm.expect(body.data.user.password).to.be.undefined);",
                  "pm.collectionVariables.set('userAToken', body.data.token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Register User B - success (201)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Bob\",\n  \"email\": \"bob@example.com\",\n  \"password\": \"password123\"\n}"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 201', () => pm.response.to.have.status(201));",
                  "pm.collectionVariables.set('userBToken', pm.response.json().data.token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Register - duplicate email (409)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alice Clone\",\n  \"email\": \"alice@example.com\",\n  \"password\": \"password123\"\n}"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 409', () => pm.response.to.have.status(409));",
                  "pm.test('status error', () => pm.expect(pm.response.json().status).to.eql('error'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Register - missing password (400)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"NoPassword\",\n  \"email\": \"nopass@example.com\"\n}"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('status 400', () => pm.response.to.have.status(400));"] }
            }
          ]
        },
        {
          "name": "Register - role in body is ignored, defaults to user",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Mallory\",\n  \"email\": \"mallory@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"admin\"\n}"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 201', () => pm.response.to.have.status(201));",
                  "pm.test('role forced to user despite request body', () => pm.expect(pm.response.json().data.user.role).to.eql('user'));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Login",
      "item": [
        {
          "name": "Login - success (200)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@example.com\",\n  \"password\": \"password123\"\n}"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('token present', () => pm.expect(body.data.token).to.be.a('string'));",
                  "pm.collectionVariables.set('userAToken', body.data.token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login - wrong password (401)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@example.com\",\n  \"password\": \"wrongpassword\"\n}"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('status 401', () => pm.response.to.have.status(401));"] }
            }
          ]
        },
        {
          "name": "Login - unknown email (401)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"nobody@example.com\",\n  \"password\": \"password123\"\n}"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('status 401 (no email enumeration)', () => pm.response.to.have.status(401));"] }
            }
          ]
        }
      ]
    },
    {
      "name": "Authenticated Requests",
      "item": [
        {
          "name": "Create task (201)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userAToken}}" }
            ],
            "url": "{{baseUrl}}/api/tasks",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Write report\",\n  \"description\": \"Quarterly summary\"\n}"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.test('userId set from token', () => pm.expect(body.data.userId).to.be.a('string'));",
                  "pm.collectionVariables.set('taskId', body.data._id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get own tasks (200)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userAToken}}" }],
            "url": "{{baseUrl}}/api/tasks"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('status 200', () => pm.response.to.have.status(200));"] }
            }
          ]
        },
        {
          "name": "Update own task (200)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userAToken}}" }
            ],
            "url": "{{baseUrl}}/api/tasks/{{taskId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"completed\": true\n}"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('status 200', () => pm.response.to.have.status(200));"] }
            }
          ]
        }
      ]
    },
    {
      "name": "Unauthorized Requests",
      "item": [
        {
          "name": "Get tasks - no token (401)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/tasks"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 401', () => pm.response.to.have.status(401));",
                  "pm.test('status error envelope', () => pm.expect(pm.response.json().status).to.eql('error'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Get tasks - malformed token (401)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer not-a-real-token" }],
            "url": "{{baseUrl}}/api/tasks"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('status 401', () => pm.response.to.have.status(401));"] }
            }
          ]
        },
        {
          "name": "Get tasks - expired token (401)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IjAwMDAwMDAwMDAwMDAwMDAwMDAwMDAwMCIsInJvbGUiOiJ1c2VyIiwiaWF0IjoxNjAwMDAwMDAwLCJleHAiOjE2MDAwMDAwMDF9.invalidsignatureplaceholder" }
            ],
            "url": "{{baseUrl}}/api/tasks",
            "description": "Use a token generated with a past exp claim (or wait out JWT_EXPIRES_IN on a real token) to verify TokenExpiredError handling."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('status 401', () => pm.response.to.have.status(401));"] }
            }
          ]
        }
      ]
    },
    {
      "name": "Forbidden & Not-Found Requests",
      "item": [
        {
          "name": "User B GET User A's task (404 - existence not leaked)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userBToken}}" }],
            "url": "{{baseUrl}}/api/tasks/{{taskId}}"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 404', () => pm.response.to.have.status(404));",
                  "pm.test('status error envelope', () => pm.expect(pm.response.json().status).to.eql('error'));",
                  "pm.test('message matches truly-missing task', () => pm.expect(pm.response.json().message).to.eql('Task not found'));"
                ]
              }
            }
          ]
        },
        {
          "name": "User B PUT User A's task (404)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userBToken}}" }
            ],
            "url": "{{baseUrl}}/api/tasks/{{taskId}}",
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"hacked\"\n}" }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('status 404', () => pm.response.to.have.status(404));"] }
            }
          ]
        },
        {
          "name": "User B DELETE User A's task (404)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{userBToken}}" }],
            "url": "{{baseUrl}}/api/tasks/{{taskId}}"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('status 404', () => pm.response.to.have.status(404));"] }
            }
          ]
        },
        {
          "name": "GET a genuinely nonexistent task (404, same message as above)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userBToken}}" }],
            "url": "{{baseUrl}}/api/tasks/000000000000000000000000"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 404', () => pm.response.to.have.status(404));",
                  "pm.test('message identical to forbidden case', () => pm.expect(pm.response.json().message).to.eql('Task not found'));"
                ]
              }
            }
          ]
        },
        {
          "name": "User B (non-admin) GET /auth/users (403)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userBToken}}" }],
            "url": "{{baseUrl}}/auth/users"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('status 403', () => pm.response.to.have.status(403));"] }
            }
          ]
        }
      ]
    },
    {
      "name": "Rate Limiting",
      "item": [
        {
          "name": "Login rate limit (429 after 5 attempts / 15 min, per IP)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"nobody@example.com\",\n  \"password\": \"wrong\"\n}"
            },
            "description": "loginLimiter allows 5 requests per 15 minutes per IP. Run this request 6+ times in a row (e.g. via Postman Runner) to see the 6th return 429. Uses its own limiter instance, independent of registerLimiter."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 401 or 429', () => pm.expect([401, 429]).to.include(pm.response.code));"
                ]
              }
            }
          ]
        },
        {
          "name": "Register rate limit (429 after 20 attempts / 15 min, per IP)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Spam\",\n  \"email\": \"{{$randomEmail}}\",\n  \"password\": \"password123\"\n}"
            },
            "description": "registerLimiter allows 20 requests per 15 minutes per IP, independent of loginLimiter's budget. Run via Postman Runner 21+ times to see the 21st return 429."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 201 or 429', () => pm.expect([201, 429]).to.include(pm.response.code));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Admin Requests",
      "item": [
        {
          "name": "Register admin directly in DB, then login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "description": "Registration always sets role=user (see Registration > 'role is ignored' test). Promote a user to admin manually in MongoDB (db.users.updateOne({email:'admin@example.com'}, {$set:{role:'admin'}})) before running this request."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "pm.collectionVariables.set('adminToken', pm.response.json().data.token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Admin GET all users (200)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/auth/users"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('status 200', () => pm.response.to.have.status(200));"] }
            }
          ]
        },
        {
          "name": "Admin GET all tasks, incl. other users' (200)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/tasks"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('status 200', () => pm.response.to.have.status(200));"] }
            }
          ]
        },
        {
          "name": "Admin PUT another user's task (200)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/api/tasks/{{taskId}}",
            "body": { "mode": "raw", "raw": "{\n  \"completed\": true\n}" }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('status 200', () => pm.response.to.have.status(200));"] }
            }
          ]
        },
        {
          "name": "Admin DELETE another user's task (200)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/tasks/{{taskId}}"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('status 200', () => pm.response.to.have.status(200));"] }
            }
          ]
        }
      ]
    }
  ]
}
